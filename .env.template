# 大模型服务提供商 (openai / google)
LLM_PROVIDER=google

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gen AI API 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com (可选，如需代理可配置，例如通过国内网关或反代)

# 多维表格配置 (示例: 飞书多维表格)
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here
LARK_APP_TOKEN=your_lark_app_token_here
LARK_TABLE_ID=your_lark_table_id_here
