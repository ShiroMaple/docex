# ── 大模型配置（固定为 MiMo-V2.5）──
LLM_PROVIDER=openai
OPENAI_API_KEY=your_mimo_api_key_here
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2.5

# ── WPS 开放平台配置 ──
# APP_ID / APP_SECRET：在 WPS 开放平台（open.wps.cn）创建应用后获取
WPS_APP_ID=your_wps_app_id_here
WPS_APP_SECRET=your_wps_app_secret_here
# BASE_ID：WPS 多维表格分享链接中 /l/ 后面的部分，例如 cbGbLglUXASe
WPS_BASE_ID=your_default_wps_file_id_here
